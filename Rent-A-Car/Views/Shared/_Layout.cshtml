<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rent_A_Car</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Rent_A_Car.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar bg-light border-end p-3">
            @{
                // determine current route values so we can mark the active nav link
                var currentController = (Context.Request.RouteValues["controller"] ?? string.Empty).ToString();
                var currentAction = (Context.Request.RouteValues["action"] ?? string.Empty).ToString();
                var isLogin = string.Equals(currentController, "Account", System.StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Login", System.StringComparison.OrdinalIgnoreCase);
                var isRegister = string.Equals(currentController, "Account", System.StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Register", System.StringComparison.OrdinalIgnoreCase);
            }
            <div class="d-flex align-items-center mb-4">
                <a class="navbar-brand fs-5 fw-bold me-2" asp-area="" asp-controller="Home" asp-action="Index">Rent_A_Car</a>
            </div>
            <ul class="nav nav-pills flex-column">
                <li class="nav-item mb-1">
                    <a class="nav-link @(string.Equals(currentController, "Home", System.StringComparison.OrdinalIgnoreCase) ? "active" : "")" aria-current="page" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <!-- Privacy/Policy removed as requested -->
                @if (User?.IsInRole("Admin") ?? false)
                {
                    <li class="nav-item mb-1">
                        <a class="nav-link @(string.Equals(currentController, "Users", System.StringComparison.OrdinalIgnoreCase) ? "active" : "")" asp-area="" asp-controller="Users" asp-action="Index">Users</a>
                    </li>
                }
            </ul>
            <div class="mt-4">
                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <div class="small text-muted mb-2">Signed in as @User.Identity.Name</div>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm @(isLogin ? "btn-primary" : "btn-outline-secondary") me-2" asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="btn btn-sm @(isRegister ? "btn-primary" : "btn-link")" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </nav>

        <div class="flex-fill">
            <main role="main" class="p-4">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
