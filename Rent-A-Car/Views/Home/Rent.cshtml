@model Rent_A_Car.Models.RentViewModel

@{
    ViewData["Title"] = "Rent car";
}

<div class="card mx-auto" style="max-width:720px;">
    <div class="card-body">
        <h4 class="card-title">Rent @Model.CarTitle</h4>
        <form asp-controller="Home" asp-action="Rent" method="post" id="rentForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CarId" />
            <input type="hidden" asp-for="CarTitle" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label">Start date</label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label">End date</label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
                <div class="col-12">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <label class="form-label">Your account email</label>
                        <input class="form-control" type="email" value="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value" readonly />
                        <input type="hidden" asp-for="Email" />
                    }
                    else
                    {
                        <label asp-for="Email" class="form-label">Your registered email</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="you@domain.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                        <div class="form-text">We currently require a registered account email to lock in a booking.</div>
                    }
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                <button id="btnLock" asp-controller="Home" asp-action="Rent" type="submit" class="btn btn-primary">Lock in booking</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function(){
            var start = document.querySelector('input[name="StartDate"]');
            var end = document.querySelector('input[name="EndDate"]');
            var btn = document.getElementById('btnLock');
            var alertDiv = document.createElement('div');
            alertDiv.id = 'availabilityAlert';
            alertDiv.className = 'alert alert-danger mt-3';
            alertDiv.style.display = 'none';
            alertDiv.innerText = 'Selected dates overlap with an existing booking. Please choose different dates.';
            var form = document.getElementById('rentForm');
            form.parentNode.insertBefore(alertDiv, form.nextSibling);

            function check() {
                if (!start || !end) return;
                var s = start.value;
                var e = end.value;
                if (!s || !e) { alertDiv.style.display='none'; btn.disabled = false; return; }

                var carId = document.querySelector('input[name="CarId"]').value;
                var url = '/Home/IsAvailable?carId=' + encodeURIComponent(carId) + '&start=' + encodeURIComponent(s) + '&end=' + encodeURIComponent(e);
                fetch(url, { method: 'GET', credentials: 'same-origin' })
                    .then(function(r){ return r.json(); })
                    .then(function(data){
                        if (!data || data.available === undefined) return;
                        if (!data.available) {
                            alertDiv.style.display = 'block';
                            btn.disabled = true;
                        } else {
                            alertDiv.style.display = 'none';
                            btn.disabled = false;
                        }
                    }).catch(function(){ /* ignore */ });
            }

            if (start && end) {
                start.addEventListener('change', check);
                end.addEventListener('change', check);
                // initial check
                check();
            }
        })();
    </script>
}
