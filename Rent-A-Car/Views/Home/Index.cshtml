@model IEnumerable<Rent_A_Car.Models.CarViewModel>

@{
    ViewData["Title"] = "Available Cars";
}

<div class="jumbotron p-4 mb-4 hero-creative">
    <div class="container-fluid py-2 text-center">
        <h2 class="slogan">Drive local. Rent global.</h2>
        <p class="slogan-sub">Find great cars near you, for any trip — city runs, weekend escapes or business travel.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3">
    <!-- Add-card as first card (admins only) -->
    @if (User?.IsInRole("Admin") ?? false)
    {
        <div class="col-sm-6 col-md-4">
            <div class="card h-100 shadow-sm add-card fixed-height">
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <h5 class="card-title">Add a car to the fleet</h5>
                    <p class="text-muted small">Share your car and earn.</p>
                    <a class="btn btn-outline-primary mt-2" asp-action="Add">Add Car</a>
                </div>
            </div>
        </div>
    }

    @foreach (var car in Model)
    {
        <div class="col-sm-6 col-md-4">
            <div class="card h-100 shadow-sm fixed-height">
                <img src="https://placehold.co/600x300?text=@(car.Make + "+" + car.Model)" class="card-img-top" alt="@car.Make @car.Model" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@car.Make @car.Model</h5>
                    <p class="card-text text-muted mb-1">Year: <strong>@car.Year</strong> · Seats: <strong>@car.Seats</strong></p>
                    <p class="card-text">@(string.IsNullOrWhiteSpace(car.Description) ? "No description provided." : car.Description)</p>
                    <div class="mt-auto d-flex justify-content-between align-items-center pt-3">
                        <span class="fs-5 fw-bold">@car.PricePerDay.ToString("C") / day</span>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-primary card-action-btn" asp-action="Rent" asp-route-id="@car.Id">Rent</a>
                            @if (User?.IsInRole("Admin") ?? false)
                            {
                                <form asp-action="Delete" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@car.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger card-action-btn" onclick="return confirm('Delete this car?');">Delete</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
