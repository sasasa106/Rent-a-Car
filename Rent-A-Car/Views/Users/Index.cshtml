@model Rent_A_Car.Models.UsersIndexViewModel

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Statistics</h1>
    <a class="btn btn-primary" asp-action="Create">Create New User</a>
</div>

<div class="row mb-4">
    <!-- Cards for Users view -->
    <div class="col-md-3 cards-users">
        <div class="card p-3">
            <div class="h6">Total users</div>
            <div class="fs-4 fw-bold">@Model.TotalUsers</div>
        </div>
    </div>
    <div class="col-md-3 cards-users">
        <div class="card p-3">
            <div class="h6">Users renting now</div>
            <div class="fs-4 fw-bold">@Model.UsersRentingNow</div>
        </div>
    </div>

    <!-- Cards for Requests view -->
    <div class="col-md-3 cards-requests" style="display:none;">
        <div class="card p-3">
            <div class="h6">Active requests</div>
            <div class="fs-4 fw-bold">@Model.ActiveRequestsNow</div>
        </div>
    </div>
    <div class="col-md-3 cards-requests" style="display:none;">
        <div class="card p-3">
            <div class="h6">Total requests</div>
            <div class="fs-4 fw-bold">@Model.TotalRequests</div>
        </div>
    </div>

    <!-- Cards for Cars view -->
    <div class="col-md-3 cards-cars" style="display:none;">
        <div class="card p-3">
            <div class="h6">Total cars</div>
            <div class="fs-4 fw-bold">@Model.TotalCars</div>
        </div>
    </div>
    <div class="col-md-3 cards-cars" style="display:none;">
        <div class="card p-3">
            <div class="h6">Rented now</div>
            <div class="fs-4 fw-bold">@Model.RentedCarsNow</div>
            <div class="text-muted small">Available: @Model.AvailableCarsNow</div>
        </div>
    </div>
    <div class="col-md-3 cards-cars" style="display:none;">
        <div class="card p-3">
            <div class="h6">Total revenue</div>
            <div class="fs-4 fw-bold">@Model.TotalRevenue.ToString("C")</div>
        </div>
    </div>
</div>
<div class="mb-3">
    <div class="btn-group" role="group" aria-label="View toggle">
        <button type="button" class="btn btn-outline-primary active" data-target="#usersTable" data-view="users">Users</button>
        <button type="button" class="btn btn-outline-primary" data-target="#requestsTable" data-view="requests">Requests</button>
        <button type="button" class="btn btn-outline-primary" data-target="#carsTable" data-view="cars">Cars</button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div id="usersTable">
    <div class="table-scroll">
        <table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Username</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
            <tbody>
            @{
                var nowUsers = DateTime.UtcNow.Date;
                var activeUserIds = Model.Requests.Where(r => r.StartDate.Date <= nowUsers && r.EndDate.Date >= nowUsers)
                                                  .Select(r => r.UserId)
                                                  .Distinct()
                                                  .ToHashSet();
            }
            @foreach (var user in Model.Users)
            {
                var isRenting = activeUserIds.Contains(user.Id);
                <tr class="@(isRenting ? "table-success-row" : "")">
                    <td>@user.Username</td>
                    <td>@user.FirstName</td>
                    <td>@user.LastName</td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                        <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Delete this user?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
</table>
    </div>
</div>

<div id="requestsTable" style="display:none;">
    <div class="table-scroll">
        <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Car</th>
                <th>User</th>
                <th>Start</th>
                <th>End</th>
                <th>Days</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
        @{
            var nowReq = DateTime.UtcNow.Date;
        }
        @foreach (var req in Model.Requests)
        {
            var isActive = req.StartDate.Date <= nowReq && req.EndDate.Date >= nowReq;
            <tr class="@(isActive ? "table-info-row" : "")">
                <td>@req.CarTitle</td>
                <td>@req.UserEmail</td>
                <td>@req.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@req.EndDate.ToString("yyyy-MM-dd")</td>
                <td>@req.DurationDays</td>
                <td class="text-end">@req.TotalPrice.ToString("C")</td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>

<div id="carsTable" style="display:none;">
    <div class="table-scroll">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Make</th>
                    <th>Model</th>
                    <th>Year</th>
                    <th>Seats</th>
                    <th class="text-end">Price / day</th>
                    <th class="text-end">Revenue</th>
                </tr>
            </thead>
            <tbody>
            @{
                var nowCars = DateTime.UtcNow.Date;
                var activeCarIds = Model.Requests.Where(r => r.StartDate.Date <= nowCars && r.EndDate.Date >= nowCars)
                                               .Select(r => r.CarId)
                                               .Distinct()
                                               .ToHashSet();
            }
            @foreach (var car in Model.Cars)
            {
                var rented = activeCarIds.Contains(car.Id);
                var carRevenue = Model.Requests.Where(r => r.CarId == car.Id).Sum(r => r.TotalPrice);
                <tr class="@(rented ? "table-warning-row" : "")">
                    <td>@car.Make</td>
                    <td>@car.Model</td>
                    <td>@car.Year</td>
                    <td>@car.Seats</td>
                    <td class="text-end">@car.PricePerDay.ToString("C")</td>
                    <td class="text-end">@carRevenue.ToString("C")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<script>
    (function(){
        var buttons = document.querySelectorAll('[data-target]');
        buttons.forEach(function(btn){
            btn.addEventListener('click', function(){
                var target = btn.getAttribute('data-target');
                var view = btn.getAttribute('data-view');
                // toggle tables
                document.querySelectorAll('[id$="Table"]').forEach(function(el){ el.style.display = 'none'; });
                document.querySelector(target).style.display = 'block';
                // toggle card groups
                document.querySelectorAll('.cards-users, .cards-requests, .cards-cars').forEach(function(el){ el.style.display = 'none'; });
                if (view === 'users') document.querySelectorAll('.cards-users').forEach(e => e.style.display = 'block');
                if (view === 'requests') document.querySelectorAll('.cards-requests').forEach(e => e.style.display = 'block');
                if (view === 'cars') document.querySelectorAll('.cards-cars').forEach(e => e.style.display = 'block');
                buttons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });
    })();
</script>
