@model Rent_A_Car.Models.UsersIndexViewModel

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Users</h1>
    <a class="btn btn-primary" asp-action="Create">Create New User</a>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card p-3">
            <div class="h6">Total requests</div>
            <div class="fs-4 fw-bold">@Model.TotalRequests</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="h6">Total revenue</div>
            <div class="fs-4 fw-bold">@Model.TotalRevenue.ToString("C")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="h6">Total cars</div>
            <div class="fs-4 fw-bold">@Model.TotalCars</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="h6">Rented now</div>
            <div class="fs-4 fw-bold">@Model.RentedCarsNow</div>
            <div class="text-muted small">Available: @Model.AvailableCarsNow</div>
        </div>
    </div>
</div>
<div class="mb-3">
    <div class="btn-group" role="group" aria-label="View toggle">
        <button type="button" class="btn btn-outline-primary active" data-target="#usersTable">Users</button>
        <button type="button" class="btn btn-outline-primary" data-target="#requestsTable">Requests</button>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div id="usersTable">
<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Username</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model.Users)
    {
        <tr>
            <td>@user.Username</td>
            <td>@user.FirstName</td>
            <td>@user.LastName</td>
            <td>@user.Email</td>
            <td>@user.PhoneNumber</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Delete this user?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@user.Id" />
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>

<div id="requestsTable" style="display:none;">
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Car</th>
                <th>User</th>
                <th>Start</th>
                <th>End</th>
                <th>Days</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var req in Model.Requests)
        {
            <tr>
                <td>@req.CarTitle</td>
                <td>@req.UserEmail</td>
                <td>@req.StartDate.ToString("yyyy-MM-dd")</td>
                <td>@req.EndDate.ToString("yyyy-MM-dd")</td>
                <td>@req.DurationDays</td>
                <td class="text-end">@req.TotalPrice.ToString("C")</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script>
    (function(){
        var buttons = document.querySelectorAll('[data-target]');
        buttons.forEach(function(btn){
            btn.addEventListener('click', function(){
                var target = btn.getAttribute('data-target');
                document.querySelectorAll('[id$="Table"]').forEach(function(el){ el.style.display = 'none'; });
                document.querySelector(target).style.display = 'block';
                buttons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });
    })();
</script>
